# ============================================================================
# .env.example — Copy this to .env and fill in your values
# ============================================================================

# ─── Backend Configuration ─────────────────────────────────────────────────
BACKEND_DEBUG=False
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# ─── Frontend Configuration ───────────────────────────────────────────────
VITE_API_BASE=http://localhost:8000
VITE_API_TIMEOUT=30000

# ─── Database Configuration ───────────────────────────────────────────────
# SQLite
DATABASE_URL=sqlite:///./aarogyaai_v2.db

# MongoDB (Optional)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/aarogyaai_db

# ─── JWT & Security ───────────────────────────────────────────────────────
JWT_SECRET=aarogyaai-super-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ─── Admin Credentials ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@aarogyaai.com
ADMIN_PASSWORD=change_this_password_123

# ─── Email Configuration (Optional) ────────────────────────────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ─── LiveKit Configuration ────────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_TOKEN_SERVER=http://localhost:3001

# ─── CORS Configuration ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── ML Model Configuration ───────────────────────────────────────────────
MODEL_PATH=./models
BATCH_SIZE=32
MAX_PREDICTION_TIME=30

# ─── File Upload Configuration ────────────────────────────────────────────
UPLOAD_DIR=./uploaded_reports
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,jpg,png,csv

# ─── Production Settings ──────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
