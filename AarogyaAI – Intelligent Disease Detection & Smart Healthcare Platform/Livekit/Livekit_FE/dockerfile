# ── Stage 1: Build ────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# At build time, all URLs point to the browser's origin (same host)
# nginx will proxy /token → backend:3001 and /livekit → livekit:7880
ENV VITE_LIVEKIT_URL=__LIVEKIT_URL__
ENV VITE_TOKEN_SERVER_URL=__TOKEN_SERVER_URL__

RUN npm run build

# ── Stage 2: Serve via nginx with reverse proxy ───────────────────
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]