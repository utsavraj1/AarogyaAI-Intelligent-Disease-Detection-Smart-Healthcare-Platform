# ============================================================================
# backend/.env.example — Backend-specific configuration
# ============================================================================

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./aarogyaai_v2.db
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/aarogyaai_db

# ─── JWT & Security ───────────────────────────────────────────────────────
JWT_SECRET=aarogyaai-super-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ─── Admin Credentials ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@aarogyaai.com
ADMIN_PASSWORD=change_this_password

# ─── Email Configuration ──────────────────────────────────────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# ─── Server Configuration ─────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=True

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:80,http://localhost:5173,http://localhost

# ─── File Paths ───────────────────────────────────────────────────────────
UPLOAD_DIR=./uploaded_reports
REPORTS_DIR=./reports_output
MODELS_DIR=./models

# ─── ML Configuration ─────────────────────────────────────────────────────
MAX_PREDICTION_TIME=30
BATCH_SIZE=32
